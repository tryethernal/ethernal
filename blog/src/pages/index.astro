---
/**
 * @fileoverview Blog homepage with hero section, featured post, category filter, and card grid.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedCard from '../components/FeaturedCard.astro';
import BlogCard from '../components/BlogCard.astro';
import CategoryFilter from '../components/CategoryFilter.vue';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => data.status === 'published');
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(sortedPosts.flatMap(p => p.data.tags))];
const categories = ['All', ...allTags];

const [featured, ...rest] = sortedPosts;
---

<BaseLayout title="Blog">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-14 pb-16">
    <!-- Hero section -->
    <div class="mb-12">
      <span class="text-sm font-medium text-primary uppercase tracking-wider">Blog</span>
      <h1 class="font-heading text-4xl sm:text-5xl font-bold text-text-primary mt-2 mb-3">
        Web3 Development Insights
      </h1>
      <p class="text-lg text-text-secondary max-w-2xl">
        Deep dives into EVM internals, smart contract patterns, and the infrastructure behind block explorers.
      </p>
    </div>

    <!-- Featured post (horizontal card) -->
    {featured && (
      <div class="mb-12" id="featured-card" data-tags={JSON.stringify(featured.data.tags)}>
        <FeaturedCard
          title={featured.data.title}
          slug={featured.id}
          description={featured.data.description}
          date={featured.data.date}
          tags={featured.data.tags}
          image={featured.data.image}
          readingTime={featured.data.readingTime}
        />
      </div>
    )}

    <!-- Category filter -->
    <div class="mb-10">
      <CategoryFilter client:load categories={categories} />
    </div>

    <!-- Post grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="post-grid">
      {rest.map(post => (
        <div data-tags={JSON.stringify(post.data.tags)}>
          <BlogCard
            title={post.data.title}
            slug={post.id}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            image={post.data.image}
            readingTime={post.data.readingTime}
          />
        </div>
      ))}
    </div>

    <!-- No results message -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-text-muted text-lg">No posts found for this category.</p>
    </div>
  </div>
</BaseLayout>

<script>
  document.addEventListener('filter-change', (e: Event) => {
    const category = (e as CustomEvent).detail;
    const grid = document.getElementById('post-grid');
    const featured = document.getElementById('featured-card');
    const noResults = document.getElementById('no-results');
    if (!grid || !noResults) return;

    let visibleCount = 0;

    // Filter featured card
    if (featured) {
      const fTags: string[] = JSON.parse(featured.dataset.tags || '[]');
      const fShow = category === 'All' || fTags.includes(category);
      featured.style.display = fShow ? '' : 'none';
      if (fShow) visibleCount++;
    }

    // Filter grid cards
    const cards = grid.querySelectorAll<HTMLElement>('[data-tags]');
    cards.forEach(card => {
      const tags: string[] = JSON.parse(card.dataset.tags || '[]');
      const show = category === 'All' || tags.includes(category);
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    noResults.classList.toggle('hidden', visibleCount > 0);
  });
</script>
