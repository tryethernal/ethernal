---
/**
 * @fileoverview Blog footer — must match landing footer (LandingFooter.vue).
 * When updating the landing footer, mirror changes here.
 * @component Footer
 */
const year = new Date().getFullYear();
const appUrl = import.meta.env.PUBLIC_APP_URL || 'https://app.tryethernal.com';
---
<footer class="blog-footer">
  <div class="footer-container">
    <!-- Row 1: Brand + Product/Integrations/Use Cases/Resources -->
    <div class="footer-row-1">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="font-heading">Ethernal</span>
        </a>
        <p class="footer-tagline">
          Open-source block explorer for any EVM chain. Built for developers, by developers.
        </p>
      </div>

      <div class="footer-col">
        <div class="footer-heading">Product</div>
        <div class="footer-link-list">
          <a href="/features" class="footer-link">Features</a>
          <a href="/pricing" class="footer-link">Pricing</a>
          <a href="/transaction-tracing" class="footer-link">Transaction Tracing</a>
          <a href="https://doc.tryethernal.com" target="_blank" rel="noopener noreferrer" class="footer-link">Docs</a>
          <a href={`${appUrl}/auth`} class="footer-link">Sign In</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-heading">Integrations</div>
        <div class="footer-link-list">
          <a href="/hardhat-block-explorer" class="footer-link">Hardhat</a>
          <a href="/anvil-block-explorer" class="footer-link">Anvil</a>
          <a href="/ganache-block-explorer" class="footer-link">Ganache</a>
          <a href="/kaleido" class="footer-link">Kaleido</a>
          <a href="/chainstack" class="footer-link">Chainstack</a>
          <a href="/github-actions" class="footer-link">GitHub Actions</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-heading">Use Cases</div>
        <div class="footer-link-list">
          <a href="/developers" class="footer-link">Developers</a>
          <a href="/teams" class="footer-link">Teams</a>
          <a href="/app-chains" class="footer-link">App Chains</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-heading">Resources</div>
        <div class="footer-link-list">
          <a href="https://github.com/tryethernal/ethernal" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a>
          <a href="https://discord.gg/jYCER6Mh" target="_blank" rel="noopener noreferrer" class="footer-link">Discord</a>
          <a href="/blog" class="footer-link">Blog</a>
          <a href="/contact-us" class="footer-link">Contact</a>
        </div>
      </div>
    </div>

    <!-- Row 2: Frameworks + Chains -->
    <div class="footer-row-2">
      <div class="footer-row-2-spacer"></div>

      <div class="footer-col">
        <div class="footer-heading">Frameworks</div>
        <div class="footer-link-list">
          <a href="/op-stack" class="footer-link">OP Stack Chains</a>
          <a href="/arbitrum-orbit" class="footer-link">Arbitrum Orbit Chains</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-heading">Chains</div>
        <div class="footer-link-list">
          <a href="/chains/ethereum" class="footer-link">Ethereum</a>
          <a href="/chains/bnb-chain" class="footer-link">BNB Chain</a>
          <a href="/chains/polygon-pos" class="footer-link">Polygon PoS</a>
          <a href="/chains/arbitrum-one" class="footer-link">Arbitrum One</a>
          <a href="/chains/base" class="footer-link">Base</a>
          <a href="/chains/optimism" class="footer-link">Optimism</a>
          <a href="/chains/blast" class="footer-link">Blast</a>
          <a href="/chains/mode" class="footer-link">Mode</a>
          <a href="/chains/zora" class="footer-link">Zora</a>
          <a href="/chains/arbitrum-nova" class="footer-link">Arbitrum Nova</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-heading">&nbsp;</div>
        <div class="footer-link-list">
          <a href="/chains/lisk" class="footer-link">Lisk</a>
          <a href="/chains/degen-chain" class="footer-link">Degen Chain</a>
          <a href="/chains/xai" class="footer-link">Xai</a>
          <a href="/chains/cyber" class="footer-link">Cyber</a>
          <a href="/chains/redstone" class="footer-link">Redstone</a>
          <a href="/chains/mint" class="footer-link">Mint</a>
          <a href="/chains/proof-of-play-apex" class="footer-link">Proof of Play</a>
          <a href="/chains/sepolia" class="footer-link">Sepolia</a>
          <a href="/chains/holesky" class="footer-link">Holesky</a>
          <a href="/chains/base-sepolia" class="footer-link">Base Sepolia</a>
          <a href="/chains/arbitrum-sepolia" class="footer-link">Arbitrum Sepolia</a>
        </div>
      </div>

      <div class="footer-col">
        <div class="footer-heading">Compare</div>
        <div class="footer-link-list">
          <a href="/etherscan-alternative" class="footer-link">vs Etherscan</a>
          <a href="/blockscout-alternative" class="footer-link">vs Blockscout</a>
          <a href="/routescan-alternative" class="footer-link">vs Routescan</a>
        </div>
      </div>
    </div>

    <!-- Copyright bar -->
    <div class="footer-divider"></div>
    <div class="footer-bottom">
      <span class="footer-copyright">&copy; {year} Ethernal. All rights reserved.</span>
      <div class="footer-bottom-right">
        <a href="/terms" class="footer-legal-link">Terms</a>
        <a href="/privacy" class="footer-legal-link">Privacy</a>
        <span class="footer-made">Made with care in France <span style="font-size: 14px;">🍷</span></span>
      </div>
    </div>
  </div>
</footer>

<style>
  .blog-footer {
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-base);
    margin-top: 0;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 32px 32px;
  }

  .footer-row-1 {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr 1.2fr;
    gap: 32px;
  }

  .footer-row-2 {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 32px;
    margin-top: 40px;
  }

  .footer-row-2-spacer {
    display: none;
  }

  .footer-brand {
    padding-right: 16px;
  }

  .footer-logo {
    text-decoration: none;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text-primary);
    display: inline-block;
    margin-bottom: 16px;
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.65;
    max-width: 260px;
    margin: 0;
  }

  .footer-heading {
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .footer-link-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--text-primary);
  }

  .footer-divider {
    height: 1px;
    margin: 32px 0;
    background: linear-gradient(90deg, transparent, var(--border-subtle), transparent);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .footer-bottom-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer-copyright,
  .footer-made {
    color: var(--text-muted);
    font-size: 13px;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .footer-legal-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s;
  }

  .footer-legal-link:hover {
    color: var(--text-secondary);
  }

  /* Responsive */
  @media (min-width: 769px) {
    .footer-row-2 {
      grid-template-columns: 1.5fr 1fr 1fr 1fr 1.2fr;
    }

    .footer-row-2-spacer {
      display: block;
    }
  }

  @media (max-width: 1024px) {
    .footer-row-1 {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-row-2 {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .footer-row-2-spacer {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .footer-container {
      padding: 40px 20px 24px;
    }

    .footer-row-1,
    .footer-row-2 {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer-bottom-right {
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
