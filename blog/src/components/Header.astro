---
/**
 * @fileoverview Blog header/navbar component with Ethernal branding.
 * @component Header
 */
---
<header class="sticky top-0 z-50 border-b border-border-subtle bg-bg-base/80 backdrop-blur-xl">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-decoration-none">
      <span class="font-heading text-xl font-semibold text-text-primary">Ethernal</span>
    </a>
    <nav class="flex items-center gap-6">
      <a href="/blog" class="text-sm text-primary font-medium hover:text-primary-light transition-colors">Blog</a>
      <a href="https://doc.tryethernal.com" target="_blank" rel="noopener noreferrer"
         class="text-sm text-text-secondary hover:text-text-primary transition-colors">Docs</a>
      <a href="https://app.tryethernal.com" target="_blank" rel="noopener noreferrer"
         class="text-sm bg-primary hover:bg-primary-light text-white px-4 py-1.5 rounded-lg font-medium transition-colors">
        Get Started
      </a>
    </nav>
  </div>
</header>
