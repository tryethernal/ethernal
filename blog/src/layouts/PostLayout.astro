---
/**
 * @fileoverview Article page layout with hero, metadata, content, and related posts.
 * @component PostLayout
 * @prop {object} post - The blog post entry from the collection
 */
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      date: Date;
      description: string;
      tags: string[];
      image?: string;
      ogImage?: string;
      readingTime?: number;
    };
  };
}

const { post } = Astro.props;
const { title, date, description, tags, image, ogImage, readingTime } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tag = tags[0] || 'Article';

// Get related posts (same tag, excluding current)
const allPosts = await getCollection('blog', ({ data }) => data.status === 'published');
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.tags.some(t => tags.includes(t)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title={title} description={description} image={image} ogImage={ogImage} plainBg ogType="article">
  <!-- Structured Data: BlogPosting -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "url": `https://tryethernal.com/blog/${post.id}`,
    "datePublished": date.toISOString().split('T')[0],
    "dateModified": date.toISOString().split('T')[0],
    "image": (ogImage || image) ? `https://tryethernal.com${ogImage || image}` : undefined,
    "author": {
      "@type": "Person",
      "name": "Antoine Gravieet",
      "url": "https://tryethernal.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Ethernal",
      "url": "https://tryethernal.com",
      "logo": { "@type": "ImageObject", "url": "https://tryethernal.com/favicon.ico" }
    },
    "keywords": tags.join(", "),
    "wordCount": readingTime ? readingTime * 250 : undefined,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://tryethernal.com/blog/${post.id}`
    }
  })} />
  <!-- Structured Data: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://tryethernal.com" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://tryethernal.com/blog" },
      { "@type": "ListItem", "position": 3, "name": title, "item": `https://tryethernal.com/blog/${post.id}` }
    ]
  })} />

  <article class="max-w-4xl mx-auto px-4 sm:px-6">
    <!-- Back link -->
    <div class="pt-8 pb-6">
      <a href="/blog" class="text-sm text-text-secondary hover:text-primary transition-colors">
        &larr; Back to Blog
      </a>
    </div>

    <!-- Hero image / generated cover -->
    {image ? (
      <div class="rounded-xl overflow-hidden mb-8 border border-border-subtle">
        <img src={image} alt={`Cover image for ${title}`} width="1200" height="514" class="w-full h-auto max-h-96 object-cover" />
      </div>
    ) : (
      <div class="rounded-xl overflow-hidden mb-8 relative aspect-[21/9] bg-gradient-to-br from-sky-600/80 via-blue-700/70 to-indigo-800/80">
        <div class="absolute inset-0 opacity-[0.15]">
          <div class="absolute top-6 right-12 w-40 h-40 border border-white/40 rounded-full"></div>
          <div class="absolute bottom-8 left-8 w-24 h-24 border border-white/30 rounded-lg rotate-45"></div>
          <div class="absolute top-1/2 left-1/3 w-20 h-20 border border-white/20 rounded-full"></div>
          <div class="absolute top-10 left-16 w-32 h-1 bg-white/20 rounded"></div>
        </div>
        <div class="absolute inset-0 flex items-end p-8">
          <p class="text-white font-heading font-bold text-2xl sm:text-3xl leading-snug drop-shadow-md max-w-2xl">
            {title}
          </p>
        </div>
      </div>
    )}

    <!-- Header -->
    <header class="mb-10">
      <h1 class="font-heading text-3xl sm:text-4xl lg:text-[2.75rem] font-bold text-text-primary leading-tight mb-4">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-text-muted">
        <span class="text-xs font-medium text-primary bg-primary/10 px-2.5 py-1 rounded">{tag}</span>
        <span>by Antoine</span>
        <span>&middot; {formattedDate}</span>
        {readingTime && <span>&middot; {readingTime} min read</span>}
      </div>
    </header>

    <!-- Article body -->
    <div class="prose prose-lg max-w-none mb-16">
      <slot />
    </div>
  </article>

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-6">
      <div class="border-t border-border-subtle pt-12">
        <h2 class="font-heading text-2xl font-semibold text-text-primary mb-8">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(rp => {
            const rpTag = rp.data.tags[0] || 'Article';
            return (
              <a href={`/blog/${rp.id}`} class="blog-card group">
                {rp.data.image ? (
                  <div class="aspect-[16/9] overflow-hidden">
                    <img src={rp.data.image} alt={`Cover image for ${rp.data.title}`}
                         width="800" height="450" loading="lazy"
                         class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                  </div>
                ) : (
                  <div class="aspect-[16/9] relative bg-gradient-to-br from-sky-600/80 via-blue-700/70 to-indigo-800/80 overflow-hidden">
                    <div class="absolute inset-0 opacity-[0.15]">
                      <div class="absolute top-4 right-8 w-24 h-24 border border-white/40 rounded-full"></div>
                      <div class="absolute bottom-4 left-4 w-14 h-14 border border-white/30 rounded-lg rotate-45"></div>
                    </div>
                    <div class="absolute inset-0 flex flex-col justify-end p-4">
                      <span class="text-[9px] uppercase tracking-widest text-white/60 font-medium mb-1">{rpTag}</span>
                      <p class="text-white font-heading font-semibold text-sm leading-snug line-clamp-2 drop-shadow-md">
                        {rp.data.title}
                      </p>
                    </div>
                  </div>
                )}
                <div class="p-4">
                  <span class="text-xs text-text-muted">{rp.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  <h3 class="font-heading text-base font-semibold text-text-primary mt-1 line-clamp-2 group-hover:text-primary transition-colors">
                    {rp.data.title}
                  </h3>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="border-t border-border-subtle pt-10 pb-4 text-center">
      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-text-primary mb-3">Ready to explore your chain?</h2>
      <p class="text-text-secondary mb-6 max-w-lg mx-auto">Connect your RPC and get a fully working block explorer in under 5 minutes. Free to start.</p>
      <a href="https://app.tryethernal.com" class="inline-flex items-center gap-2 px-8 py-3 rounded-full text-white font-semibold text-sm tracking-wide transition-all duration-200 hover:opacity-90 hover:shadow-lg hover:shadow-primary/30" style="background: linear-gradient(90deg, #3D95CE, #5DAAE0);">
        Get Started
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
