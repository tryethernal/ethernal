{
  "brand": {
    "name": "Ethernal",
    "tagline": "Etherscan for your blockchain",
    "description": "Open-source block explorer for EVM-based chains",
    "origin": "Made with care in France 🍷",
    "website": "https://tryethernal.com",
    "app_url": "https://app.ethernal.com",
    "github": "https://github.com/tryethernal/ethernal",
    "discord": "https://discord.gg/jYCER6Mh",
    "docs": "https://doc.tryethernal.com",
    "blog": "https://blog.tryethernal.com",
    "contact_email": "contact@tryethernal.com"
  },

  "logo": {
    "type": "wordmark",
    "text": "Ethernal",
    "font_family": "Exo",
    "font_weight": 600,
    "usage_notes": "The logo is TEXT ONLY — the word 'Ethernal' in Exo 600. There is NO icon, symbol, or SVG logo. Never fabricate one.",
    "variants": {
      "primary": { "color": "#3D95CE", "usage": "On light backgrounds, in-app" },
      "white": { "color": "#FFFFFF", "usage": "On dark backgrounds, landing page, marketing" },
      "gradient": { "background": "linear-gradient(90deg, #3D95CE, #5DAAE0)", "usage": "Special emphasis, hero text" }
    },
    "minimum_clear_space": "0.5em on all sides",
    "forbidden": [
      "Do not add icons or symbols before/after the wordmark",
      "Do not use fonts other than Exo",
      "Do not stretch, skew, or rotate the wordmark",
      "Do not use drop shadows or outlines on the wordmark"
    ]
  },

  "colors": {
    "primary": {
      "default": "#3D95CE",
      "light": "#5DAAE0",
      "dark": "#29648E",
      "gradient": "linear-gradient(90deg, #3D95CE, #5DAAE0)",
      "usage": "Primary CTAs, links, accent elements, gradient text"
    },
    "semantic": {
      "success": "#22C55E",
      "error": "#E72732",
      "warning": "#E78227",
      "info": "#2196F3"
    },
    "dark_theme": {
      "background": "#0B1120",
      "card": "#111827",
      "card_hover": "#1A2234",
      "surface": "#151D2E",
      "navbar": "rgba(11, 17, 32, 0.8)"
    },
    "light_theme": {
      "background": "#F5F5F5",
      "primary": "#3D95CE",
      "secondary": "#424242",
      "accent": "#29648E"
    },
    "text": {
      "primary": "#F1F5F9",
      "secondary": "#94A3B8",
      "muted": "#64748B",
      "on_primary": "#FFFFFF"
    },
    "borders": {
      "subtle": "rgba(61, 149, 206, 0.22)",
      "glow": "rgba(61, 149, 206, 0.4)",
      "section_divider": "rgba(61, 149, 206, 0.08)"
    }
  },

  "typography": {
    "heading": {
      "family": "Exo",
      "weights": [400, 500, 600, 700],
      "usage": "Page headlines, section titles, logo, pricing amounts",
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=Exo:wght@400;500;600;700&display=swap"
    },
    "body": {
      "family": "Roboto",
      "weights": [300, 400, 500, 700],
      "usage": "Body text, descriptions, UI elements, buttons",
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap"
    },
    "monospace": {
      "family": "JetBrains Mono",
      "fallback": "Fira Code, monospace",
      "usage": "Code blocks, terminal previews, technical content"
    },
    "scale": {
      "hero_headline": "clamp(2.2rem, 5vw, 3.5rem)",
      "section_headline": "clamp(1.8rem, 4vw, 2.8rem)",
      "card_title": "1.15rem",
      "body": "1.05rem",
      "small": "0.875rem",
      "caption": "13px"
    },
    "style_notes": {
      "letter_spacing_headlines": "-0.02em",
      "line_height_body": "1.7",
      "uppercase_labels": "12px, font-weight 600, letter-spacing 0.1em"
    }
  },

