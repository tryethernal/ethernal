        <div class="v-progress-linear__buffer" style="width: 0%;"></div>
        <transition-stub name="fade-transition" appear="false" persisted="false" css="true">
          <div class="v-progress-linear__indeterminate">
            <div class="v-progress-linear__indeterminate long"></div>
            <div class="v-progress-linear__indeterminate short"></div>
          </div>
        </transition-stub>
        <!---->
      </div>
    </div>
    <!---->
    <!---->
    <div class="v-card-title">
      <h4>L1 Chain</h4>
    </div>
    <div class="v-card-text">
      <form class="v-form" novalidate="">
        <div class="v-row">
          <div class="v-col v-col-12">
            <div class="v-alert v-theme--light text-warning v-alert--density-compact v-alert--variant-tonal mb-3" role="alert">
              <!----><span class="v-alert__underlay"></span>
              <!---->
              <div class="v-alert__prepend"><i class="mdi-alert-circle mdi v-icon notranslate v-theme--light" style="font-size: 28px; height: 28px; width: 28px;" aria-hidden="true" density="compact"></i></div>
              <div class="v-alert__content">
                <!---->
                <!----> Only Ethereum Mainnet and Arbitrum One are supported as L1 for Orbit rollups at the moment. If you need support for another L1, please reach out.
              </div>
              <!---->
              <!---->
            </div>
            <div class="v-alert v-theme--light text-info v-alert--density-compact v-alert--variant-tonal mb-6" role="alert">
              <!----><span class="v-alert__underlay"></span>
